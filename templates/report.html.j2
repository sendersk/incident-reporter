<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Incident Report</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 40px; }
        .incident { border: 1px solid #ddd; padding: 10px; margin-bottom: 10px; }
        .title { font-weight: bold; }
    </style>
</head>
<body>

<h1>Incident Report</h1>
<p>Generated: {{ generated_at }}</p>
<p>Total incidents: {{ incidents|length }}</p>

<hr>

{% for inc in incidents %}
<div class="incident">
    <div class="title">#{{ inc.id }} - {{ inc.title }}</div>
    <div class="desc">{{ inc.description }}</div>
</div>
{% endfor %}

</body>
</html>